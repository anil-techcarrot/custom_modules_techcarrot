<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_profile_change_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.profile.change.request.reject.wizard.form</field>
        <field name="model">hr.profile.change.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Profile Change Request">
                <group string="Request Details">
                    <field name="request_id" readonly="1"/>
                    <field name="employee_name" readonly="1"/>
                </group>
                <group string="Rejection Details">
                    <field name="rejection_reason"
                           nolabel="1"
                           placeholder="Clearly explain why this request is being rejected. This message will be emailed to the employee and saved permanently in the audit trail."
                           style="min-height:100px;"/>
                </group>
                <div class="alert alert-warning" role="alert">
                    <strong>Important:</strong> This rejection reason will be
                    <strong>emailed directly to the employee</strong> and
                    saved permanently in the audit trail.
                    Please be clear and professional.
                </div>
                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm Rejection"
                            type="object"
                            class="btn-danger"
                            data-hotkey="v"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>