<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         CATEGORY — shown as section header in User Settings
    ══════════════════════════════════════════════════════════════ -->
    <record id="module_category_profile_change" model="ir.module.category">
        <field name="name">Profile Change Approval</field>
        <field name="description">
            Controls who can view and approve employee profile change requests
            submitted from the self-service portal.
        </field>
        <field name="sequence">100</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         GROUP — one checkbox: "HR Reviewer"
         Anyone with this group can:
           • See the "Profile Change Requests" menu
           • View all submitted requests
           • Approve / Reject / Re-open requests
    ══════════════════════════════════════════════════════════════ -->
    <record id="group_profile_change_hr_reviewer" model="res.groups">
        <field name="name">HR Reviewer</field>
        <field name="category_id"
               ref="module_category_profile_change"/>
        <field name="comment">
            Users in this group can review, approve, and reject employee
            profile change requests from the portal.
        </field>
        <!-- Auto-include Odoo HR Manager so they always have access -->
        <field name="implied_ids"
               eval="[(4, ref('hr.group_hr_manager'))]"/>
    </record>

</odoo>