<odoo>
    <template id="portal_employee_profile_personal_inherit_extra"
              inherit_id="employee_self_service_portal.portal_employee_profile_personal">

        <!-- Add after Work Information OR anywhere you want -->
        <xpath expr="//div[@class='card mb-4 shadow-sm'][.//h5[contains(., 'Work Information')]]"
               position="after">

            <!-- ================= Private Contact ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Private Contact</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Email</label>
                            <input type="text" class="form-control"
                                   t-att-value="employee.private_email or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Phone</label>
                            <input type="text" class="form-control"
                                   t-att-value="employee.private_phone or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Bank Accounts</label>
                            <input type="text" class="form-control"
                                   t-att-value="', '.join(employee.bank_account_ids.mapped('acc_number')) if employee.bank_account_ids else ''"
                                   readonly="readonly"/>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ================= Personal Information ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Legal Name</label>
                            <input class="form-control" t-att-value="employee.legal_name or ''" readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Birthday</label>
                            <input class="form-control" t-att-value="employee.birthday or ''" readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Place of Birth</label>
                            <input class="form-control" t-att-value="employee.place_of_birth or ''" readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Payslip Language</label>
                            <input class="form-control" t-att-value="employee.lang or ''" readonly="readonly"/>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ================= Visa & Work Permit ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Visa  &amp; Work Permit</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Visa No</label>
                            <input class="form-control" t-att-value="employee.visa_no or ''" readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Work Permit No</label>
                            <input class="form-control" t-att-value="employee.permit_no or ''" readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Work Permit File</label>
                            <input type="file" class="form-control" disabled="disabled"/>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ================= Citizenship ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Citizenship</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Nationality</label>
                            <input class="form-control"
                                   t-att-value="employee.country_id.name or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Non Resident</label>
                            <input class="form-control"
                                   t-att-value="'Yes' if employee.is_non_resident else 'No'"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Identification No</label>
                            <input class="form-control"
                                   t-att-value="employee.identification_id or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>SSN No</label>
                            <input class="form-control"
                                   t-att-value="employee.ssnid or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Passport No</label>
                            <input class="form-control"
                                   t-att-value="employee.passport_id or ''"
                                   readonly="readonly"/>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ================= Family ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Family</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Disabled</label>
                            <input class="form-control"
                                   t-att-value="'Yes' if employee.disabled else 'No'"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Children</label>
                            <input class="form-control"
                                   t-att-value="employee.children or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Certificate</label>
                            <input class="form-control"
                                   t-att-value="employee.certificate or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Field of Study</label>
                            <input class="form-control"
                                   t-att-value="employee.study_field or ''"
                                   readonly="readonly"/>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ================= Languages ================= -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Languages</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Mother Tongue</label>
                            <input class="form-control"
                                   t-att-value="employee.mother_tongue_id.name or ''"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label>Languages Known</label>
                            <input class="form-control"
                                   t-att-value="', '.join(employee.language_known_ids.mapped('name')) if employee.language_known_ids else ''"
                                   readonly="readonly"/>
                        </div>

                    </div>
                </div>
            </div>

        </xpath>
    </template>
</odoo>