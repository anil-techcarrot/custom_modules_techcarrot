<odoo>
    <template id="portal_employee_profile_payroll"
              inherit_id="employee_self_service_portal.portal_employee_profile_personal">

        <!-- Change section to payroll -->
        <xpath expr="//t[@t-set='section']" position="replace">
            <t t-set="section" t-value="'payroll'"/>
        </xpath>

        <!-- Replace whole content -->
        <xpath expr="//t[@t-set='section_content']" position="replace">

            <t t-set="section_content">

                <!-- ============================= -->
                <!-- Contract Overview -->
                <!-- ============================= -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Contract Overview</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Contract</label>
                                <input type="date" class="form-control"
                                       t-att-value="employee.contract_date_start"
                                       readonly="readonly"/>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Wage Type</label>
                                <input type="text" class="form-control"
                                       t-att-value="employee.wage_type"
                                       readonly="readonly"/>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Contract Type</label>
                                <input type="text" class="form-control"
                                       t-att-value="employee.contract_type_id.name"
                                       readonly="readonly"/>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Pay Category</label>
                                <input type="text" class="form-control"
                                       t-att-value="employee.structure_type_id.name"
                                       readonly="readonly"/>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ============================= -->
                <!-- Annual Leave -->
                <!-- ============================= -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Annual Leave Provision</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Leaves</label>
                                <input type="text" class="form-control"
                                       t-att-value="employee.l10n_ae_number_of_leave_days"
                                       readonly="readonly"/>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ============================= -->
                <!-- Tax -->
                <!-- ============================= -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Tax Deductions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-bold">TDS Deduction</label>
                                <input type="text" class="form-control"
                                       t-att-value="employee.l10n_in_tds"
                                       readonly="readonly"/>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ============================= -->
                <!-- Manual Salary -->
                <!-- ============================= -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Manual Salary Components</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">

                            <t t-foreach="[
                                ('Basic Salary Manual','basic_salary_manual'),
                                ('HRA Manual','hra_manual'),
                                ('Flexi Basket Manual','flexi_manual'),
                                ('Statutory Bonus Manual','statutory_manual'),
                                ('Gratuity Manual','gratuity_manual'),
                                ('PF Manual','pf_manual'),
                                ('Medical Insurance Manual','medical_manual')
                            ]" t-as="field">

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">
                                        <t t-esc="field[0]"/>
                                    </label>
                                    <input type="text" class="form-control"
                                           t-att-value="getattr(employee, field[1]) or ''"
                                           readonly="readonly"/>
                                </div>

                            </t>

                        </div>
                    </div>
                </div>

            </t>

        </xpath>

    </template>
</odoo>