<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_employee_profile_payroll">
        <t t-call="employee_self_service_portal.portal_employee_profile_base">

            <!-- Active Tab -->
            <t t-set="section" t-value="'payroll'"/>

            <!-- Page Content -->
            <t t-set="section_content">

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="fa fa-money me-2"></i>Payroll Details
                        </h5>
                    </div>

                    <div class="card-body">

                        <!-- ERROR MESSAGE -->
                        <t t-if="error">
                            <div class="alert alert-danger">
                                <t t-esc="error"/>
                            </div>
                        </t>

                        <form method="post" action="/my/employee/payroll">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <!-- Contract Info -->
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label>Joining Date</label>
                                    <input type="date" name="contract_date_start"
                                           class="form-control"
                                           t-att-value="employee.contract_date_start"/>
                                </div>

                                <div class="col-md-4">
                                    <label>Wage Type</label>
                                    <select name="wage_type" class="form-control">
                                        <option value="monthly"
                                            t-att-selected="employee.wage_type == 'monthly'">Monthly</option>
                                        <option value="hourly"
                                            t-att-selected="employee.wage_type == 'hourly'">Hourly</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Salary -->
                            <h6 class="mt-4">Salary Breakdown</h6>

                            <div class="row">
                                <div class="col-md-4">
                                    <label>Basic</label>
                                    <input type="number" name="basic_salary_manual"
                                           class="form-control"
                                           t-att-value="employee.basic_salary_manual"/>
                                </div>

                                <div class="col-md-4">
                                    <label>HRA</label>
                                    <input type="number" name="hra_manual"
                                           class="form-control"
                                           t-att-value="employee.hra_manual"/>
                                </div>

                                <div class="col-md-4">
                                    <label>Flexi</label>
                                    <input type="number" name="flexi_manual"
                                           class="form-control"
                                           t-att-value="employee.flexi_manual"/>
                                </div>

                                <div class="col-md-4 mt-2">
                                    <label>PF</label>
                                    <input type="number" name="pf_manual"
                                           class="form-control"
                                           t-att-value="employee.pf_manual"/>
                                </div>

                                <div class="col-md-4 mt-2">
                                    <label>Medical</label>
                                    <input type="number" name="medical_manual"
                                           class="form-control"
                                           t-att-value="employee.medical_manual"/>
                                </div>

                                <div class="col-md-4 mt-2">
                                    <label>Gratuity</label>
                                    <input type="number" name="gratuity_manual"
                                           class="form-control"
                                           t-att-value="employee.gratuity_manual"/>
                                </div>
                            </div>

                            <!-- Leave -->
                            <div class="mt-4">
                                <label>Annual Leave</label>
                                <input type="number" name="l10n_ae_number_of_leave_days"
                                       class="form-control"
                                       t-att-value="employee.l10n_ae_number_of_leave_days"/>
                            </div>

                            <!-- Tax -->
                            <div class="mt-3">
                                <label>TDS</label>
                                <input type="number" name="l10n_in_tds"
                                       class="form-control"
                                       t-att-value="employee.l10n_in_tds"/>
                            </div>

                            <!-- Submit -->
                            <div class="mt-4 text-center">
                                <button type="submit" class="btn btn-primary">
                                    Save Payroll
                                </button>
                            </div>

                        </form>
                    </div>
                </div>

            </t>

        </t>
    </template>

</odoo>