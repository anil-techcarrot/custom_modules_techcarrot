<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_employee_profile_payroll" name="Employee Payroll Portal">
        <t t-call="employee_self_service_portal.portal_employee_profile_base">
            <t t-set="section" t-value="'payroll'"/>
            <t t-set="section_content">

                <div id="messageContainer" style="display:none;">
                    <div id="successMessage" class="alert alert-success alert-dismissible fade" style="display:none;">
                        <i class="fa fa-check-circle me-2"></i>
                        <span id="successText"></span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <div id="errorMessage" class="alert alert-danger alert-dismissible fade" style="display:none;">
                        <i class="fa fa-exclamation-triangle me-2"></i>
                        <span id="errorText"></span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                </div>

                <form id="payrollForm" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fa fa-file-contract text-primary me-2"></i>Contract Overview
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract Start Date</label>
                                    <input type="date" name="contract_date_start"
                                           t-att-value="employee.contract_date_start or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Wage Type</label>
                                    <input type="text" name="wage_type"
                                           t-att-value="employee.wage_type or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Annual Leave Days</label>
                                    <input type="number" name="l10n_ae_number_of_leave_days"
                                           t-att-value="employee.l10n_ae_number_of_leave_days or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">TDS</label>
                                    <input type="number" name="l10n_in_tds"
                                           t-att-value="employee.l10n_in_tds or ''"
                                           class="form-control"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fa fa-money-bill text-primary me-2"></i>Salary Components
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Basic Salary</label>
                                    <input type="number" step="0.01" name="basic_salary_manual"
                                           t-att-value="employee.basic_salary_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">HRA</label>
                                    <input type="number" step="0.01" name="hra_manual"
                                           t-att-value="employee.hra_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Flexi</label>
                                    <input type="number" step="0.01" name="flexi_manual"
                                           t-att-value="employee.flexi_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Statutory</label>
                                    <input type="number" step="0.01" name="statutory_manual"
                                           t-att-value="employee.statutory_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Gratuity</label>
                                    <input type="number" step="0.01" name="gratuity_manual"
                                           t-att-value="employee.gratuity_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">PF</label>
                                    <input type="number" step="0.01" name="pf_manual"
                                           t-att-value="employee.pf_manual or ''"
                                           class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Medical</label>
                                    <input type="number" step="0.01" name="medical_manual"
                                           t-att-value="employee.medical_manual or ''"
                                           class="form-control"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-body text-center">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save me-1"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </form>

                <script type="text/javascript">
                <![CDATA[
                    document.addEventListener('DOMContentLoaded', function () {
                        const form = document.getElementById('payrollForm');
                        form.addEventListener('submit', function (e) {
                            e.preventDefault();
                            fetch('/my/employee/payroll', {
                                method: 'POST',
                                body: new FormData(form)
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    showMessage('Payroll updated successfully!', 'success');
                                } else {
                                    showMessage(data.error || 'Unknown error', 'error');
                                }
                            })
                            .catch(() => showMessage('Network error. Please try again.', 'error'));
                        });

                        function showMessage(text, type) {
                            const container = document.getElementById('messageContainer');
                            const successMsg = document.getElementById('successMessage');
                            const errorMsg = document.getElementById('errorMessage');
                            successMsg.style.display = 'none';
                            errorMsg.style.display = 'none';
                            successMsg.classList.remove('show');
                            errorMsg.classList.remove('show');
                            if (type === 'success') {
                                document.getElementById('successText').textContent = text;
                                successMsg.style.display = 'block';
                                successMsg.classList.add('show');
                            } else {
                                document.getElementById('errorText').textContent = text;
                                errorMsg.style.display = 'block';
                                errorMsg.classList.add('show');
                            }
                            container.style.display = 'block';
                            container.scrollIntoView({ behavior: 'smooth' });
                            setTimeout(() => {
                                successMsg.classList.remove('show');
                                errorMsg.classList.remove('show');
                            }, 5000);
                        }
                    });
                ]]>
                </script>

            </t>
        </t>
    </template>
</odoo>