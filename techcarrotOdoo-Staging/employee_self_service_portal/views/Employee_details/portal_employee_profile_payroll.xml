<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="portal_employee_profile_payroll" name="Portal Employee Payroll" page="True">

            <t t-call="website.layout">
                <div class="container mt-4">
                    <h2>Payroll</h2>

                    <form action="/my/employee/payroll" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <label>Contract Start</label>
                        <input type="date" name="contract_date_start"
                               t-att-value="employee.contract_date_start"
                               class="form-control mb-2"/>

                        <label>Wage Type</label>
                        <input type="text" name="wage_type"
                               t-att-value="employee.wage_type"
                               class="form-control mb-2"/>

                        <label>Leave Days</label>
                        <input type="number" name="l10n_ae_number_of_leave_days"
                               t-att-value="employee.l10n_ae_number_of_leave_days"
                               class="form-control mb-2"/>

                        <button type="submit" class="btn btn-primary">Save</button>
                    </form>

                </div>
            </t>

        </template>

    </data>
</odoo>