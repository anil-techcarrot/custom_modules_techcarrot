<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_employee_profile_payroll">
        <t t-call="employee_self_service_portal.portal_employee_profile_base">

            <t t-set="section" t-value="'payroll'"/>

            <t t-set="section_content">

                <div class="card">
                    <div class="card-header">
                        <h5>Payroll</h5>
                    </div>

                    <div class="card-body">

                        <form method="post" action="/my/employee/payroll">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="mb-3">
                                <label>Joining Date</label>
                                <input type="date"
                                       name="contract_date_start"
                                       t-att-value="employee.contract_date_start"
                                       class="form-control"/>
                            </div>

                            <div class="mb-3">
                                <label>Basic Salary</label>
                                <input type="number"
                                       name="basic_salary_manual"
                                       t-att-value="employee.basic_salary_manual"
                                       class="form-control"/>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="btn btn-primary">
                                    Save
                                </button>
                            </div>

                        </form>

                    </div>
                </div>

            </t>

        </t>
    </template>

</odoo>