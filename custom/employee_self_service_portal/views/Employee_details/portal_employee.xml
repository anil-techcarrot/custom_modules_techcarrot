<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="portal_employee_profile_techcarrot" name="Portal Employee TechCarrot Details">
    <t t-call="employee_self_service_portal.portal_employee_profile_base">
      <t t-set="section" t-value="'techcarrot'"/>
      <t t-set="section_content">

        <div id="messageContainer" style="display:none;">
          <div id="successMessage" class="alert alert-success alert-dismissible fade" role="alert" style="display:none;">
            <i class="fa fa-check-circle me-2"></i><span id="successText"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <div id="errorMessage" class="alert alert-danger alert-dismissible fade" role="alert" style="display:none;">
            <i class="fa fa-exclamation-triangle me-2"></i><span id="errorText"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>

        <form id="techcarrotForm" action="/my/employee/techcarrot" method="post" enctype="multipart/form-data">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

          <!-- ===== GENERAL INFORMATION ===== -->
          <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
              <h5 class="mb-0"><i class="fa fa-building text-primary me-2"></i>General Information</h5>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="editMode" onchange="toggleEditMode()"/>
                <label class="form-check-label" for="editMode">Edit Mode</label>
              </div>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Practice</label>
                  <input type="text" name="practice" class="form-control" t-att-value="employee.practice or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Sub Practice</label>
                  <input type="text" name="sub_practice" class="form-control" t-att-value="employee.sub_practice or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Practice Head</label>
                  <input type="text" name="practice_heads_id" class="form-control" t-att-value="employee.practice_heads_id.name if employee.practice_heads_id else ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Engagement Location</label>
                  <input type="text" name="engagement_location" class="form-control" t-att-value="employee.engagement_location or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Employee Inside UAE</label>
                  <select name="emp_inside_uae" class="form-select" disabled="">
                    <option value="0" t-att-selected="'selected' if not employee.emp_inside_uae else None">No</option>
                    <option value="1" t-att-selected="'selected' if employee.emp_inside_uae else None">Yes</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Branch Name</label>
                  <input type="text" name="branch_name" class="form-control" t-att-value="employee.branch_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Bank Name</label>
                  <input type="text" name="bank_name" class="form-control" t-att-value="employee.bank_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Payroll</label>
                  <input type="text" name="payroll" class="form-control" t-att-value="employee.payroll or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Mentor Name</label>
                  <input type="text" name="mentor_names_id" class="form-control" t-att-value="employee.mentor_names_id.name if employee.mentor_names_id else ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">DOJ (Date of Joining)</label>
                  <input type="date" name="doj" class="form-control" t-att-value="employee.doj" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Original Hire Date</label>
                  <input type="date" name="original_hire_date" class="form-control" t-att-value="employee.original_hire_date" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Current Work Address</label>
                  <input type="text" name="current_address" class="form-control" t-att-value="employee.current_address or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">ISD Code</label>
                  <input type="text" name="phone_code_1" class="form-control" t-att-value="employee.phone_code_1 or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Employment Status</label>
                  <input type="text" name="employement_status_id" class="form-control" t-att-value="employee.employement_status_id.name if employee.employement_status_id else ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Notice Period (days)</label>
                  <input type="number" name="notice_period" class="form-control" t-att-value="employee.notice_period or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Resignation Date</label>
                  <input type="date" name="resign_date" class="form-control" t-att-value="employee.resign_date" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">End Date</label>
                  <input type="date" name="end_date" class="form-control" t-att-value="employee.end_date" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">LWD (Last Working Day)</label>
                  <input type="date" name="lwd" class="form-control" t-att-value="employee.lwd" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Customer / Account Name</label>
                  <input type="text" name="customer_acc_name" class="form-control" t-att-value="employee.customer_acc_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Candidate Source</label>
                  <input type="text" name="candidate_source" class="form-control" t-att-value="employee.candidate_source or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Exit Type</label>
                  <input type="text" name="exit_type_id" class="form-control" t-att-value="employee.exit_type_id.name if employee.exit_type_id else ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Exit Reason</label>
                  <input type="text" name="exit_reason_id" class="form-control" t-att-value="employee.exit_reason_id.name if employee.exit_reason_id else ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Current / Additional Role</label>
                  <input type="text" name="current_role" class="form-control" t-att-value="employee.current_role or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Industry Start Date</label>
                  <input type="date" name="industry_start_date" class="form-control" t-att-value="employee.industry_start_date" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Experience</label>
                  <input type="text" name="experience" class="form-control" t-att-value="employee.experience or ''" readonly="readonly"/>
                </div>
              </div>
            </div>
          </div>

          <!-- ===== CAREER DETAILS ===== -->
          <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
              <h5 class="mb-0"><i class="fa fa-briefcase text-primary me-2"></i>Career Details</h5>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">No. of Career Breaks</label>
                  <input type="number" name="no_of_carrer_break" class="form-control" t-att-value="employee.no_of_carrer_break or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Career Break</label>
                  <input type="text" name="career_break" class="form-control" t-att-value="employee.career_break or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Career Break Detail</label>
                  <input type="text" name="career_break_detail" class="form-control" t-att-value="employee.career_break_detail or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Career Break Start Date</label>
                  <input type="date" name="career_break_start_date" class="form-control" t-att-value="employee.career_break_start_date" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Career Break End Date</label>
                  <input type="date" name="career_break_end_date" class="form-control" t-att-value="employee.career_break_end_date" readonly="readonly"/>
                </div>
              </div>
            </div>
          </div>

          <!-- ===== INDUSTRY REFERENCE ===== -->
          <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
              <h5 class="mb-0"><i class="fa fa-industry text-primary me-2"></i>Industry / Reference Details</h5>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Last Reporting Manager Mobile</label>
                  <input type="tel" name="last_report_manager_mob_no" class="form-control" t-att-value="employee.last_report_manager_mob_no or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Reference Name</label>
                  <input type="text" name="industry_ref_name" class="form-control" t-att-value="employee.industry_ref_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Reference Email</label>
                  <input type="email" name="industry_ref_email" class="form-control" t-att-value="employee.industry_ref_email or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Reference Mobile Number</label>
                  <input type="tel" name="industry_ref_mob_no" class="form-control" t-att-value="employee.industry_ref_mob_no or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Previous Company Name</label>
                  <input type="text" name="previous_company_name" class="form-control" t-att-value="employee.previous_company_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Designation</label>
                  <input type="text" name="designation" class="form-control" t-att-value="employee.designation or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Period in Company</label>
                  <input type="text" name="period_in_company" class="form-control" t-att-value="employee.period_in_company or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Reason of Leaving</label>
                  <input type="text" name="reason_of_leaving" class="form-control" t-att-value="employee.reason_of_leaving or ''" readonly="readonly"/>
                </div>
              </div>
            </div>
          </div>

          <!-- ===== EDUCATION ===== -->
          <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
              <h5 class="mb-0"><i class="fa fa-graduation-cap text-primary me-2"></i>Education</h5>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Certificate Level</label>
                  <select name="certificate" class="form-select" disabled="">
                    <option value="">Select Level</option>
                    <option value="graduate" t-att-selected="'selected' if employee.certificate == 'graduate' else None">Graduate</option>
                    <option value="bachelor" t-att-selected="'selected' if employee.certificate == 'bachelor' else None">Bachelor</option>
                    <option value="master" t-att-selected="'selected' if employee.certificate == 'master' else None">Master</option>
                    <option value="doctor" t-att-selected="'selected' if employee.certificate == 'doctor' else None">Doctor</option>
                    <option value="other" t-att-selected="'selected' if employee.certificate == 'other' else None">Other</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Field of Study</label>
                  <input type="text" name="study_field" class="form-control" t-att-value="employee.study_field or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Institution Name</label>
                  <input type="text" name="institute_name" class="form-control" t-att-value="employee.institute_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Degree Name</label>
                  <input type="text" name="degree_name" class="form-control" t-att-value="employee.degree_name or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Field of Study (Degree)</label>
                  <input type="text" name="field_of_study" class="form-control" t-att-value="employee.field_of_study or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Start Date of Degree</label>
                  <input type="date" name="start_date_of_degree" class="form-control" t-att-value="employee.start_date_of_degree" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Completion Date of Degree</label>
                  <input type="date" name="completion_date_of_degree" class="form-control" t-att-value="employee.completion_date_of_degree" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Year of Passing</label>
                  <input type="text" name="year_of_passing" class="form-control" t-att-value="employee.year_of_passing or ''" readonly="readonly"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Score</label>
                  <input type="text" name="score" class="form-control" t-att-value="employee.score or ''" readonly="readonly"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Degree Certificate Legalisation</label>
                  <input type="text" name="degree_certificate_legal" class="form-control" t-att-value="employee.degree_certificate_legal or ''" readonly="readonly"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Certification Obtained</label>
                  <input type="text" name="certification_obtained" class="form-control" t-att-value="employee.certification_obtained or ''" readonly="readonly"/>
                </div>
              </div>
            </div>
          </div>

          <!-- ===== FORM ACTIONS ===== -->
          <div class="card shadow-sm">
            <div class="card-body text-center">
              <div id="formActions" style="display:none;">
                <button type="button" class="btn btn-secondary me-2" onclick="cancelEdit()"><i class="fa fa-times me-1"></i>Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fa fa-check me-1"></i>Save Changes</button>
              </div>
              <div id="viewActions">
                <button type="button" class="btn btn-outline-primary" onclick="enableEditMode()"><i class="fa fa-edit me-1"></i>Edit</button>
              </div>
            </div>
          </div>
        </form>

        <script type="text/javascript">
        <![CDATA[
          let originalFormData = {};
          function toggleEditMode() { document.getElementById('editMode').checked ? enableEditMode() : disableEditMode(); }
          function enableEditMode() {
            document.getElementById('editMode').checked = true;
            const fd = new FormData(document.getElementById('techcarrotForm'));
            originalFormData = {};
            for (let [k,v] of fd.entries()) originalFormData[k] = v;
            document.querySelectorAll('#techcarrotForm input, #techcarrotForm select').forEach(el => {
              if (el.type !== 'hidden') { el.removeAttribute('readonly'); el.removeAttribute('disabled'); }
            });
            document.getElementById('formActions').style.display = 'block';
            document.getElementById('viewActions').style.display = 'none';
          }
          function disableEditMode() {
            document.getElementById('editMode').checked = false;
            document.querySelectorAll('#techcarrotForm input, #techcarrotForm select').forEach(el => {
              if (el.type !== 'hidden') { el.setAttribute('readonly','readonly'); if (el.tagName === 'SELECT') el.setAttribute('disabled','disabled'); }
            });
            document.getElementById('formActions').style.display = 'none';
            document.getElementById('viewActions').style.display = 'block';
          }
          function cancelEdit() {
            for (let [k,v] of Object.entries(originalFormData)) { const i = document.querySelector('[name="'+k+'"]'); if(i) i.value=v; }
            disableEditMode();
          }
          document.getElementById('techcarrotForm').addEventListener('submit', function(e) {
            e.preventDefault();
            fetch('/my/employee/techcarrot', { method: 'POST', body: new FormData(this) })
              .then(r => r.json())
              .then(data => {
                if (data.success) { alert('Saved successfully!'); disableEditMode(); }
                else { alert('Error: ' + (data.error || 'Unknown error')); }
              })
              .catch(() => alert('Network error. Please try again.'));
          });
        ]]>
        </script>

        <style>
        <![CDATA[
          .form-label { font-weight: 600; color: #495057; }
          .form-control[readonly], .form-select[disabled] { background-color: #f8f9fa; }
          .card { transition: all .3s ease; }
          .card:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,.1) !important; }
        ]]>
        </style>
      </t>
    </t>
  </template>
</odoo>