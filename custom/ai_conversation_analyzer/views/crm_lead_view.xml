<odoo>
    <record id="view_crm_lead_form_inherit_ai" model="ir.ui.view">
        <field name="name">crm.lead.form.ai</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="AI Analysis">
                    <field name="conversation_summary"/>
                    <field name="sentiment"/>
                    <field name="meeting_required"/>
                    <field name="client_visit"/>

                    <button name="action_analyze_conversation"
                            string="Analyze with AI"
                            type="object"
                            class="btn-primary"/>
                </group>

            </xpath>

        </field>
    </record>
</odoo>