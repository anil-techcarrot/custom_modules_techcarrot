<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_employee_form_techcarret_view" model="ir.ui.view">
        <field name="name">hr.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']" position="after">
                <page string="Work Log" name="work_log">
                    <field name="work_log_ids" mode="list" readonly="1" force_save="1">
                        <list editable="bottom">
                            <field name="rental_id"/>
                            <field name="partner_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
                <page string="Work Entry" name="work_entry">
                    <field name="work_entry_ids" mode="list" readonly="1" force_save="1">
                        <list editable="top" readonly="state in ('Invoiced')">
                            <field name="import_id" column_invisible="1"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="worked_days"/>
                            <field name="state" column_invisible="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
