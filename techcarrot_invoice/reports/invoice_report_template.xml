<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_techcarrot_invoices_document">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <style>
<!--                        body {-->
<!--                            font-size: 18px; /* Set the base font size for the report */-->
<!--                        }-->
                        table, th, td {
                            border:1px solid black;
                            padding-left:10px;
                            padding:5px;
                        }
                        .br-right {
                            border:1px solid black;
                            padding:5px;
                        }
                        .text-right {
                            text-align: end;
                        }
                    </style>
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-6" name="logo">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <img t-if="o.company_id.logo" class="o_company_logo_small" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                                </div>
                            </div>
                            <div class="col-6 text-end" name="div_billing_address" >
<!--                                <div name="partner_header" class="row mb-4">-->
                                <div class="text-end no-border" style="font-size:24px;"><b><t t-esc="o.company_id.name"/></b></div>
                                <div t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                                <div class="text-end no-border" ><t t-esc="o.company_id.vat"/></div>
                            </div>
                        </div>
                        <h3 class="text-center">TAX INVOICE</h3>
                        <br></br>

                        <div class="row mb-4">
                            <div class="col-6" name="div_billing_address">
                                <div name="customer_address" >
                                    <strong>Bill To</strong>
                                </div>
                                <div name="partner_header">
                                    <div t-field="o.partner_shipping_id"
                                         t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                                </div>
                            </div>
                            <div class="col-6 text-end" name="div_billing_address">
                                <div name="customer_address" >
                                    <strong>Invoice#</strong>
                                </div>
                                <div name="address_not_same_as_shipping" >
                                    <address class="mb-0" t-field="o.name" />
                                </div>
                            </div>
                        </div>

                        <div class="clearfix invoice_main">
                        <div class="page mb-4">
                            <div class="oe_structure"></div>
                            <table width="100%">
                                <thead>
                                    <tr style="background-color:#d6d6d6;">
                                        <th name="inv_date" width="25%" class="  text-start">Invoice Date</th>
                                        <th name="terms" width="25%" class="  text-start">Terms</th>
                                        <th name="due_date" width="25%" class="  text-start">Due Date</th>
                                        <th name="due_date" width="25%" class="  text-start">P.O.#</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr style="border-bottom:none;border-top:none" >
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <span t-field="o.invoice_date"></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <span t-field="o.invoice_payment_term_id.note"></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <span t-field="o.invoice_date_due"></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <t t-if="o.line_ids.sale_line_ids">
                                                <span t-field="o.line_ids.sale_line_ids.order_id.po_no"></span>
                                            </t>
                                        </td>
                                    </tr>
                                </tbody>

                            </table>
                            <br></br>
                            <table width="100%"  style="border:none;" name="invoice_line_table">
                                <thead>
                                    <tr style="background-color:#d6d6d6;">
                                        <th name="th_description" width="35%" class="text-start"><span>Item &amp; Description</span></th>
                                        <th name="th_quantity" width="10%"  class="text-end"><span>Qty</span></th>
                                        <th name="th_quantity" width="12%" class="text-end"><span>Rate</span></th>
                                        <th name="th_quantity" width="15%" class="text-end"><span>Taxable Amount</span></th>
                                        <th name="th_quantity" width="13%" class="text-end"><span>VAT</span></th>
                                        <th name="th_quantity" width="15%" class="text-center"><span>Total Amount</span></th>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                                    <t t-foreach="lines" t-as="line">
                                        <tr style="border-bottom:none;border-top:none" t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                            <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">
                                                <td name="account_invoice_line_name" style="border-bottom:none;border-top:none">
                                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">Bacon Burger</span>
<!--                                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">Bacon Burger</span>-->
                                                </td>
                                                <td name="td_quantity" class="text-end text-nowrap" style="border-bottom:none;border-top:none">
                                                    <span t-field="line.quantity">3.00</span>
                                                    <span t-field="line.product_uom_id"  groups="uom.group_uom">units</span>
                                                </td>
                                                <td name="td_price_unit" style="border-bottom:none;border-top:none" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.price_unit">9.00</span>
                                                </td>
                                                <td name="td_subtotal" style="border-bottom:none;border-top:none" class="text-end o_price_total">
                                                    <span class="text-nowrap" t-field="line.price_subtotal">27.00</span>
                                                </td>
                                                <t t-set="taxes" t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
                                                <td name="td_taxes" style="border-bottom:none;border-top:none" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                                    <span t-field="line.l10n_ae_vat_amount" id="line_tax_ids">Tax 15%</span>
                                                </td>

                                                <td name="td_subtotal" style="border-bottom:none;border-top:none" class="text-center o_price_total">
                                                    <span class="text-nowrap" t-field="line.price_total">27.00</span>
                                                </td>
                                            </t>

                                        </tr>
                                    </t>
                                    <t t-set="lines" t-value="o.invoice_line_ids"/>
                                    <t t-foreach="range(max(3-len(lines),0))" t-as="ln">
                                        <tr style="color: #ffffff;border-bottom:none;border-top:none" >
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >Packs</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >Particulars</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                        </tr>
                                    </t>
                                    <tr style="border-top:none;">
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;" ></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                    </tr>
                                </tbody>
                            </table>
                            <br/>
                            <br/>
                            <div>
                                <div id="right-elements" t-attf-class="#{'col-8' if report_type != 'html' else 'col-12 col-md-4'} ms-5 d-inline-block float-end">
                                    <div id="total" class="clearfix row mt-n3">
                                        <div class="ms-auto">
                                            <table class="o_total_table table  table-borderless avoid-page-break-inside" style="border : none">

                                                <!-- Tax totals summary (invoice currency) -->
                                                <t t-if="o.tax_totals" >
                                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                                    <t t-set="currency" t-value="o.currency_id.name"/>
                                                    <tr class="o_total" style="border-bottom: 0.5px solid black;">
                                                        <td class="text-end"><strong>Total</strong></td>
                                                        <td class="text-end o_price_total">
                                                            <span class="text-nowrap"
                                                                  t-field="o.amount_total"
                                                            >31.05</span>
                                                        </td>
                                                    </tr>

                                                </t>

                                                <!--Payments-->
                                            </table>
                                            <div class="mb-3">
                                                <div class="mb-2">
                                                    <p class="text-muted lh-sm" >
                                                        Total amount in words:<b><span t-field="o.amount_total_words"></span></b>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        </div>
                        <div class="page mb-4">
                            <t t-if="o.company_id.currency_id != o.currency_id">
                                <strong><span>Tax Summary</span>( 1<span t-field="o.currency_id.name"></span>=<span t-field="o.invoice_currency_rate"></span> AED)</strong>
                            </t>
                            <t t-else="">
                                <h3>Tax Summary</h3>
                            </t>
                            <table width="100%">
                                <thead>
                                    <tr style="background-color:#d6d6d6;">
                                        <th name="inv_date" width="25%" class="  text-start">Tax Details</th>
                                        <th name="terms" width="25%" class="  text-end">Taxable Amount(AED)</th>
                                        <th name="due_date" width="25%" class="  text-end">Tax Amount(AED)</th>
                                        <th name="due_date" width="25%" class="  text-end">Total Amount(AED)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-set="currency" t-value="o.currency_id.name"/>
                                    <tr style="border-bottom:none;border-top:none" >
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <span >Standard Rate (5%)</span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <span t-field="o.amount_untaxed"></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <span t-field="o.amount_tax"></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <span t-field="o.amount_total"></span>
                                        </td>
                                    </tr>
                                    <tr style="border-bottom:none;border-top:none" >
                                        <td name="inv_dt" style="border-bottom:none;border-top:none">
                                            <span ><b>Total</b></span>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <b><span t-field="o.amount_untaxed_signed"></span></b>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <b><span t-field="o.amount_tax_signed"></span></b>
                                        </td>
                                        <td name="inv_dt" style="border-bottom:none;border-top:none" class="  text-end">
                                            <b><span t-field="o.amount_total_signed"></span></b>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <br></br>
<!--                            <div id="terms_and_bank_details" class="row mb-4">-->
                        <table width="100%" class="table table-borderless" style="border : 1px solid black;">
<!--                        <table width="100%" >-->
                            <tr style="border : 1px solid black;">
                                <td colspan="3" style="border-right : 1px solid black;"><b>Bank Details for AED Transfers</b></td>
                                <td colspan="3"><b>Bank Details for USD Transfers</b></td>
                            </tr>
                            <t t-set="aed_bank" t-value="o.company_id.bank_ids.filtered(lambda l: l.currency_id.name == 'AED')"/>
                            <t t-set="usd_bank" t-value="o.company_id.bank_ids.filtered(lambda l: l.currency_id.name == 'USD')"/>
                            <tr style="line-height: 0.8;">
                                <td width="15%">
                                    <span>Account Title</span>
                                </td>
                                <td width="3%"><strong>:</strong></td>
                                <td width="32%" style="border-right : 1px solid black;">
                                    <span t-field="aed_bank.partner_id.name"/>
                                </td>
                                <td width="15%">
                                    <span>Account Title</span>
                                </td>
                                <td width="3%"><strong>:</strong></td>
                                <td width="32%" style="border-right : 1px solid black;">
                                    <span t-field="usd_bank.partner_id.name"/>
                                </td>
                            </tr>
                            <tr style="line-height: 0.8;">
                                <td>
                                    <span>Account No.</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td style="border-right : 1px solid black;">
                                    <span t-field="aed_bank.acc_number"/>
                                </td>
                                <td>
                                    <span>Account No.</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td>
                                    <span t-field="usd_bank.acc_number"/>
                                </td>
                            </tr>
                            <tr style="line-height: 0.8;">
                                <td>
                                    <span>IBAN</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td style="border-right : 1px solid black;">
                                    <span t-field="aed_bank.iban_no"/>
                                </td>
                                <td>
                                    <span>IBAN</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td>
                                    <span t-field="usd_bank.iban_no"/>
                                </td>
                            </tr>
                            <tr style="line-height: 0.8;">
                                <td>
                                    <span>Beneficiary Bank</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td style="border-right : 1px solid black;">
                                    <span t-field="aed_bank.bank_id.name"/>
                                </td>
                                <td>
                                    <span>Beneficiary Bank</span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td>
                                    <span t-field="usd_bank.bank_id.name"/>
                                </td>
                            </tr>
                            <tr style="line-height: 0.8;">
                                <td>
                                    <span>SWIFT Code  </span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td style="border-right : 1px solid black;">
                                    <span t-field="aed_bank.bank_id.bic"/>
                                </td>
                                <td>
                                    <span>SWIFT Code  </span>
                                </td>
                                <td ><strong>:</strong></td>
                                <td>
                                    <span t-field="usd_bank.bank_id.bic"/>
                                </td>
                            </tr>

                        </table>
<!--                    </div>-->

                        </div>

                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <br></br>
                        <table class="o_total_table table  table-borderless avoid-page-break-inside" style="border : none">

                                                <!-- Tax totals summary (invoice currency) -->
                                                    <tr class="o_total" style="border-bottom: 0.5px solid black;">
                                                            <td></td>
                                                    </tr>
                        </table>
                    </div>
                </t>
            </t>
        </template>

        <template id="report_techcarrot_invoices">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="techcarrot_invoice.report_techcarrot_invoices_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </template>

    </data>
</odoo>
